{
  "name": "faclie",
  "version": "1.0.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "desktop:dev": "electron .",
    "desktop:pack": "electron-packager . Faclie --platform=win32 --arch=x64 --out=dist --overwrite --ignore=\"(docs|dist|\\.git|\\.next/cache)\"",
    "desktop:build": "npm run build && electron-packager . Faclie --platform=win32 --arch=x64 --out=dist --overwrite --ignore=\"(docs|dist|\\.git|\\.next/cache)\"",
    "desktop:zip": "tar -a -c -f dist/Faclie-Portable.zip -C dist/Faclie-win32-x64 ."
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.2",
    "canvas-confetti": "^1.9.4",
    "clsx": "^2.1.1",
    "framer-motion": "^12.42.2",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.23.0",
    "next": "16.2.10",
    "openai": "^6.45.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^33.0.0",
    "electron-builder": "^24.13.3",
    "electron-packager": "^17.1.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "build": {
    "appId": "com.faclie.simulator",
    "productName": "Faclie",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!docs/**/*",
      "!dist/**/*",
      "!.git/**/*",
      "!.next/cache/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}
